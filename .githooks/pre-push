#!/bin/sh
# Type-check the frontend before push.
# Vite dev server silently ignores TS errors; tsc catches them here so broken
# builds can't reach Render.

echo "pre-push: running frontend TypeScript check..."
cd "$(git rev-parse --show-toplevel)/frontend" || exit 1

npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo ""
  echo "pre-push: TypeScript errors found — push aborted."
  echo "Fix the errors above, then push again."
  exit 1
fi

echo "pre-push: TypeScript check passed."
